#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
script_path="$repo_root/scripts/send_and_summarize.py"
runtime_env_sh="$repo_root/scripts/runtime_env.sh"

if [[ ! -f "$runtime_env_sh" ]]; then
  echo "poe-external-review: missing runtime env helper at $runtime_env_sh" >&2
  exit 2
fi

# shellcheck disable=SC1090
source "$runtime_env_sh"

config_file="$(poe_review_get_runtime_env_path)"

if ! command -v python3 >/dev/null 2>&1; then
  echo "poe-external-review: python3 is not installed or not on PATH." >&2
  exit 127
fi

if [[ ! -f "$script_path" ]]; then
  echo "poe-external-review: missing helper script at $script_path" >&2
  exit 2
fi

poe_review_load_runtime_env_defaults "$config_file"

if [[ -n "${POE_API_KEY:-}" ]]; then
  export POE_API_KEY
fi

if [[ -n "${POE_API_BASE_URL:-}" ]]; then
  export POE_API_BASE_URL
fi

exec python3 "$script_path" "$@"
