#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
delegate="$script_dir/../extras/claude-workspace-bridge/bin/claude-poe-review"

if [[ ! -x "$delegate" ]]; then
  echo "claude-poe-review: missing advanced bridge implementation at $delegate" >&2
  exit 127
fi

exec "$delegate" "$@"
